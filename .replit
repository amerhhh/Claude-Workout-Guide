modules = ["nodejs-22"]

run = "pnpm --filter @workoutguide/mcp-server start"

[deployment]
run = ["sh", "-c", "pnpm --filter @workoutguide/mcp-server start"]
build = ["sh", "-c", "corepack enable && pnpm install --frozen-lockfile && pnpm build && pnpm db:migrate"]
deploymentTarget = "vm"

[[ports]]
localPort = 3000
externalPort = 80
